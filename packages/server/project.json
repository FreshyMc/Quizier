{
  "name": "server",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "packages/server/src",
  "projectType": "application",
  "targets": {
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx watch src/main.ts",
        "cwd": "packages/server"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.json",
        "cwd": "packages/server"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint . --ext .ts",
        "cwd": "packages/server"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "vitest run --passWithNoTests",
        "cwd": "packages/server"
      }
    },
    "seed": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/seed-admin.ts",
        "cwd": "packages/server"
      }
    },
    "seed-example": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsx scripts/seed-example-quiz.ts",
        "cwd": "packages/server"
      }
    }
  },
  "tags": []
}
