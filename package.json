{
  "name": "quizier",
  "version": "1.0.0",
  "private": true,
  "description": "Quizier Nx monorepo",
  "scripts": {
    "nx": "nx",
    "seed:admin": "nx run server:seed",
    "format": "prettier --write .",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "verify:build": "nx run-many -t build --outputStyle=static",
    "dev": "nx run-many -t dev --projects=client,server --parallel=2 --outputStyle=stream",
    "dev:server": "nx run server:dev",
    "dev:client": "nx run client:dev"
  },
  "workspaces": [
    "packages/*"
  ],
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "@eslint/js": "^9.39.0",
    "@types/node": "^25.2.3",
    "@types/react": "^19.2.14",
    "@typescript-eslint/eslint-plugin": "^8.55.0",
    "@typescript-eslint/parser": "^8.55.0",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "nx": "^22.5.1",
    "prettier": "^3.8.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
